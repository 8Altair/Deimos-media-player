<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf">
    
    <!-- Style for player control buttons -->
    <Style x:Key="PlayerIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SmallPlayerIconButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerIconButtonStyle}">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
    </Style>

    <!-- Style for SVG icons -->
    <Style x:Key="PlayerIconStyle" TargetType="{x:Type svg:SvgViewbox}">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Stretch" Value="Uniform"/>
    </Style>
    
</ResourceDictionary>