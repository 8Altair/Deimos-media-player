<Window x:Class="Deimos.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:Deimos.UI"
        mc:Ignorable="d"
        Title="Deimos"
        WindowState="Maximized"
        MinWidth="620"
        MinHeight="500"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="0" 
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    
    <Border x:Name="WindowFrame" Background="{StaticResource WindowBackgroundBrush}" Margin="0">
        <!-- Root layout for custom title bar and application content -->
        <Grid Background="{StaticResource WindowBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/> <!-- Custom title bar -->
                <RowDefinition Height="*"/> <!-- Main application content -->
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0" Background="{StaticResource TitleBarBackgroundBrush}" 
                    BorderBrush="#223447" BorderThickness="0,0,0,1" 
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10"/> <!-- Left spacing -->
                        <ColumnDefinition Width="Auto"/> <!-- Application icon -->
                        <ColumnDefinition Width="10"/> <!-- Spacing -->
                        <ColumnDefinition Width="*"/> <!-- Title -->
                        <ColumnDefinition Width="Auto"/> <!-- Minimize -->
                        <ColumnDefinition Width="Auto"/> <!-- Maximize / Restore -->
                        <ColumnDefinition Width="Auto"/> <!-- Close -->
                    </Grid.ColumnDefinitions>

                    <!-- Deimos logo -->
                    <Image Grid.Column="1" Width="20" Height="20" VerticalAlignment="Center" Stretch="Uniform" 
                           Source="Assets/Icons/Deimos_logo.png"/>
                    
                    <!-- Custom title text -->
                    <TextBlock Grid.Column="3" Text="Deimos" VerticalAlignment="Center" 
                               Foreground="{StaticResource PrimaryTextBrush}" 
                               FontFamily="Cinzel, Segoe UI" FontSize="15" FontWeight="SemiBold"/>

                    <!-- Minimize button -->
                    <Button Grid.Column="4" Width="40" Height="30" VerticalAlignment="Center" 
                            Style="{StaticResource TitleBarButtonStyle}" 
                            Click="Minimize_Click" ToolTip="Minimize">—</Button>
                    
                    <!-- Maximize / restore button -->
                    <Button Grid.Column="5" Width="40" Height="30" VerticalAlignment="Center" 
                            Style="{StaticResource TitleBarButtonStyle}" 
                            Click="MaximizeRestore_Click" ToolTip="Maximize / Restore">▢</Button>
                    
                    <!-- Close button -->
                    <Button Grid.Column="6" Width="40" Height="30" VerticalAlignment="Center" 
                            Style="{StaticResource CloseTitleBarButtonStyle}" Click="Close_Click" 
                            ToolTip="Close">✕</Button>
                </Grid>
            </Border>

            <!-- Main application content -->
            <DockPanel Grid.Row="1" Background="{StaticResource WindowBackgroundBrush}">

                <!-- Main menu -->
                <Menu DockPanel.Dock="Top"> <!-- Container for top-level menu items -->
                    <MenuItem x:Name="MenuItemFile" Header="_File"> <!-- File menu with Alt+F -->
                        <MenuItem x:Name="MenuItemExit" Header="E_xit" Tag="Destructive" Click="ExitClick"/> <!-- Exit command with X access key -->
                    </MenuItem>

                    <MenuItem Header="_List"> <!-- Playlist management menu -->
                        <MenuItem Header="Add static" Command="{Binding AddStaticCommand}"/>
                        <MenuItem Header="Edit static" Command="{Binding EditStaticCommand}"/>
                        <Separator/> <!-- Visual separation between static and dynamic options -->
                        <MenuItem Header="Add" Click="AddMenu_Click"/>
                        <MenuItem Header="Edit"/>
                        <MenuItem Header="Remove" Command="{Binding RemoveSelectedCommand}"/>
                    </MenuItem>
                </Menu>

                <!-- Playback controls section -->
                <Border DockPanel.Dock="Bottom" Margin="6,0,6,6" Padding="6" 
                        Style="{StaticResource SectionBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Timeline row -->
                            <RowDefinition Height="12"/> <!-- Spacing row -->
                            <RowDefinition Height="Auto"/> <!-- Transport controls row -->
                        </Grid.RowDefinitions>

                        <!-- Timeline and time labels -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Current time -->
                                <ColumnDefinition Width="10"/> <!-- Left spacing -->
                                <ColumnDefinition Width="*"/> <!-- Seek timeline -->
                                <ColumnDefinition Width="10"/> <!-- Right spacing -->
                                <ColumnDefinition Width="Auto"/> <!-- Total time -->
                            </Grid.ColumnDefinitions>

                            <Label x:Name="CurrentTimeLabel" Grid.Column="0" Content="00:00:00"/> <!-- Current playback time -->

                            <!-- Playback seek control -->
                            <Grid x:Name="SeekBar" Grid.Column="2" Height="22" Background="Transparent" 
                                  SizeChanged="SeekBar_OnSizeChanged" MouseLeftButtonDown="SeekBar_OnMouseLeftButtonDown" 
                                  MouseMove="SeekBar_OnMouseMove" MouseLeftButtonUp="SeekBar_OnMouseLeftButtonUp">
                                <Border Height="8" CornerRadius="4" 
                                        Background="{StaticResource DarkTrackBrush}" 
                                        VerticalAlignment="Center"/>
                                <Border x:Name="SeekBarProgress" Height="8" CornerRadius="4" 
                                        Background="{StaticResource AccentBrush}" 
                                        VerticalAlignment="Center" HorizontalAlignment="Left" Width="0"/>
                                <Canvas Height="16" VerticalAlignment="Center" Background="Transparent">
                                    <Ellipse x:Name="SeekBarThumb" Width="16" Height="16" 
                                             Fill="{StaticResource AccentBrush}" Stroke="White" 
                                             StrokeThickness="1" Canvas.Left="0" Canvas.Top="0"/>
                                </Canvas>
                            </Grid>

                            <Label x:Name="TotalTimeLabel" Grid.Column="4" Content="00:00:00"/> <!-- Total playback time -->
                        </Grid>

                        <!-- Now playing and transport controls -->
                        <Grid Grid.Row="2">
                            <!-- Current track label -->
                            <Grid x:Name="NowPlayingViewport" Width="260" ClipToBounds="True"
                                  VerticalAlignment="Center" HorizontalAlignment="Left">
                                <TextBlock x:Name="NowPlaying" VerticalAlignment="Center" 
                                           Style="{StaticResource NowPlayingTextBlockStyle}" 
                                           Text="{Binding NowPlayingText}">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform x:Name="NowPlayingTransform"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Grid>

                            <!-- Media control buttons (Play stays in the true center) -->
                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <WrapPanel Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button x:Name="Shuffle" Style="{StaticResource ShuffleToggleButtonStyle}" 
                                            ToolTip="Shuffle" Command="{Binding ShuffleCommand}">
                                        <svg:SvgViewbox Style="{StaticResource PlayerIconStyle}" 
                                                        Source="Assets/Icons/Controls/shuffle.svg"/> <!-- Shuffle icon -->
                                    </Button>

                                    <Button x:Name="Repeat" Style="{StaticResource RepeatToggleButtonStyle}" 
                                            ToolTip="Repeat" Command="{Binding RepeatCommand}">
                                        <svg:SvgViewbox Style="{StaticResource PlayerIconStyle}" 
                                                        Source="Assets/Icons/Controls/repeat.svg"/> <!-- Repeat icon -->
                                    </Button>

                                    <Button x:Name="Stop" Style="{StaticResource SmallPlayerIconButtonStyle}" 
                                            ToolTip="Stop" Command="{Binding StopCommand}">
                                        <svg:SvgViewbox Style="{StaticResource PlayerIconStyle}" 
                                                        Source="Assets/Icons/Controls/stop.svg"/> <!-- Stop icon -->
                                    </Button>

                                    <Button x:Name="Previous" Style="{StaticResource PlayerIconButtonStyle}" 
                                            ToolTip="Previous" Command="{Binding PreviousCommand}">
                                        <svg:SvgViewbox Style="{StaticResource PlayerIconStyle}" 
                                                        Source="Assets/Icons/Controls/previous.svg"/> <!-- Previous icon -->
                                    </Button>
                                </WrapPanel>

                                <Button x:Name="PlayPause" Grid.Column="1" Style="{StaticResource PlayerIconButtonStyle}" 
                                        ToolTip="Play / Pause" Command="{Binding PlayPauseCommand}">
                                    <svg:SvgViewbox Style="{StaticResource PlayerIconStyle}" 
                                                    Source="{Binding PlayPauseIconPath}"/> <!-- Play / pause icon -->
                                </Button>

                                <WrapPanel Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Button x:Name="Next" Style="{StaticResource PlayerIconButtonStyle}" 
                                            ToolTip="Next" Command="{Binding NextCommand}">
                                        <svg:SvgViewbox Style="{StaticResource PlayerIconStyle}" 
                                                        Source="Assets/Icons/Controls/next.svg"/> <!-- Next icon -->
                                    </Button>

                                    <Slider Width="90" Height="22" Margin="8,0,0,0"
                                            Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay, 
                                            UpdateSourceTrigger=PropertyChanged}" 
                                            IsMoveToPointEnabled="True" ToolTip="Volume"/>
                                </WrapPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Playlist and media surface -->
                <Border Margin="6" Style="{StaticResource SectionBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250" MinWidth="200" MaxWidth="450"/> <!-- Playlist column -->
                            <ColumnDefinition Width="5"/> <!-- Splitter column -->
                            <ColumnDefinition Width="*"/> <!-- Media column -->
                        </Grid.ColumnDefinitions>

                        <!-- Playlist view -->
                        <ListView x:Name="LvPlayList" Grid.Column="0" ItemsSource="{Binding PlayList}"
                                  ItemTemplate="{StaticResource PlaylistItemTemplate}"
                                  SelectedItem="{Binding SelectedMedia, Mode=TwoWay}"
                                  MouseDoubleClick="PlayList_OnMouseDoubleClick">
                            <ListView.Resources>
                                <Style TargetType="ScrollBar"  
                                       BasedOn="{StaticResource PlaylistScrollBarStyle}"/>
                            </ListView.Resources>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" 
                                       BasedOn="{StaticResource PlaylistItemStyle}"/> <!-- Shared playlist row styling -->
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <!-- Resizable divider -->
                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

                        <!-- Media playback surface -->
                        <Border Grid.Column="2" Margin="4,0,0,0" Padding="6" 
                                Background="{StaticResource PlaybackSurfaceBrush}" 
                                BorderBrush="{StaticResource ControlBorderBrush}" 
                                BorderThickness="1" CornerRadius="4">
                            <Grid>
                                <MediaElement x:Name="Player" LoadedBehavior="Manual" UnloadedBehavior="Manual"/> <!-- Main playback surface -->
                                <Image x:Name="ImageViewer"
                                       Source="{Binding CurrentPlayingMedia.ImagePath}"
                                       Visibility="{Binding IsImagePreviewVisible, 
                                       Converter={StaticResource BoolToVisibility}}" Stretch="Uniform"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </DockPanel>
        </Grid>
    </Border>
</Window>
