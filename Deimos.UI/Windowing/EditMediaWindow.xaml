<Window x:Class="Deimos.UI.Windowing.EditMediaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Media"
        Width="520"
        MinWidth="480"
        MinHeight="420"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="True">
    <Window.Resources>
        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style x:Key="FormButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ListHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource PlaybackSurfaceBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box" Width="16" Height="16" CornerRadius="2"
                                    Background="{StaticResource SurfaceBackgroundBrush}"
                                    BorderBrush="{StaticResource ControlBorderBrush}"
                                    BorderThickness="1">
                                <Path x:Name="CheckMark"
                                      Data="M 2 8 L 6 12 L 14 3"
                                      Stroke="{StaticResource AccentBrush}"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10" BorderThickness="1" BorderBrush="{StaticResource ControlBorderBrush}" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource TitleBarBackgroundBrush}" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Edit Media"/>
                    <Button Grid.Column="2" Width="36" Height="28" Margin="0,2,4,2"
                            Style="{StaticResource CloseTitleBarButtonStyle}" Content="✕" Click="Close_OnClick"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="12" Style="{StaticResource SectionBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" Text="Title"/>
                        <TextBox x:Name="TitleTextBox" Grid.Row="0" Grid.Column="1" Margin="0,6" MinHeight="28"
                                 Style="{StaticResource FormTextBoxStyle}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" Text="File path"/>
                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FilePathTextBox" Grid.Column="0" MinHeight="28" Margin="0,0,8,0"
                                     Style="{StaticResource FormTextBoxStyle}"/>
                            <Button Grid.Column="1" Width="90" MinHeight="28" Content="Browse..."
                                    Style="{StaticResource FormButtonStyle}" Click="BrowseFile_OnClick"/>
                        </Grid>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                                   Text="Image path"/>
                        <TextBox x:Name="ImagePathTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6" MinHeight="28"
                                 Style="{StaticResource FormTextBoxStyle}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                                   Text="Duration (hh:mm:ss)"/>
                        <TextBox x:Name="DurationTextBox" Grid.Row="3" Grid.Column="1" Margin="0,6" MinHeight="28"
                                 Style="{StaticResource FormTextBoxStyle}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                                   Text="Artist"/>
                        <TextBox x:Name="ArtistTextBox" Grid.Row="4" Grid.Column="1" Margin="0,6" MinHeight="28"
                                 Style="{StaticResource FormTextBoxStyle}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                                   Text="Album"/>
                        <TextBox x:Name="AlbumTextBox" Grid.Row="5" Grid.Column="1" Margin="0,6" MinHeight="28"
                                 Style="{StaticResource FormTextBoxStyle}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                                   Text="Is playing"/>
                        <CheckBox x:Name="IsPlayingCheckBox" Grid.Row="6" Grid.Column="1" Margin="0,6" 
                                  VerticalAlignment="Center"/>

                        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" 
                                    HorizontalAlignment="Right">
                            <Button Width="90" Height="32" Margin="0,0,8,0" Content="Cancel" IsCancel="True"
                                    Style="{StaticResource FormButtonStyle}" Click="Cancel_OnClick"/>
                            <Button Width="90" Height="32" Content="Save" IsDefault="True" Click="Save_OnClick"
                                    Style="{StaticResource FormButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
