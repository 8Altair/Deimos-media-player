<Window x:Class="Deimos.UI.Windowing.AddMediaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Media"
        Width="520"
        MinWidth="480"
        MinHeight="420"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Margin="12" Style="{StaticResource SectionBorderStyle}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                           Text="Title"/>
                <TextBox x:Name="TitleTextBox" Grid.Row="0" Grid.Column="1" Margin="0,6" MinHeight="28"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                           Text="File path"/>
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FilePathTextBox" Grid.Column="0" MinHeight="28" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Width="90" MinHeight="28" Content="Browse..." Click="BrowseFile_OnClick"/>
                </Grid>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                           Text="Image path"/>
                <TextBox x:Name="ImagePathTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6" MinHeight="28"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                           Text="Duration (hh:mm:ss)"/>
                <TextBox x:Name="DurationTextBox" Grid.Row="3" Grid.Column="1" Margin="0,6" MinHeight="28"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                           Text="Artist"/>
                <TextBox x:Name="ArtistTextBox" Grid.Row="4" Grid.Column="1" Margin="0,6" MinHeight="28"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                           Text="Album"/>
                <TextBox x:Name="AlbumTextBox" Grid.Row="5" Grid.Column="1" Margin="0,6" MinHeight="28"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,6,12,6" VerticalAlignment="Center" 
                           Text="Is playing"/>
                <CheckBox x:Name="IsPlayingCheckBox" Grid.Row="6" Grid.Column="1" Margin="0,6" 
                          VerticalAlignment="Center"/>

                <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    <Button Width="90" Height="32" Margin="0,0,8,0" Content="Cancel" IsCancel="True"/>
                    <Button Width="90" Height="32" Content="Save" IsDefault="True" Click="Save_OnClick"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
